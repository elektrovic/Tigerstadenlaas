# Kontaktskjema — e-post via Resend (se README «Kontaktskjema»)
# Uten RESEND_API_KEY svarer /api/kontakt 503 og skjemaet ber folk ringe.
RESEND_API_KEY=
# Valgfritt — standard er post@tigerstadenlas.no
KONTAKT_MOTTAKER=
# Valgfritt — avsender må være et domene verifisert i Resend.
# Standard bruker Resends testavsender (onboarding@resend.dev).
KONTAKT_AVSENDER=

# Google Business Profile / Places API — se README «Google-anmeldelser»
# Nøkkelen brukes KUN på serveren og må aldri sjekkes inn i git.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
